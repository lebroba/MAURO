# apps/web/.env.local.example
#
# Copy this file to apps/web/.env.local and fill in real values.
# .env.local is gitignored; this template (with empty values) is committed
# so contributors know what variables MAURO needs.

# ---------------------------------------------------------------
# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
# ---------------------------------------------------------------

# Project URL, e.g. https://abcdefghij.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose in client bundle. Used by the browser
# Supabase client for RLS-protected reads/writes scoped to the signed-in user.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses RLS. Never import from client code.
# Used by:
#   - Vercel API routes (e.g., the render-on-write path)
#   - Postgres function calls that require elevated privileges
# Per packages/sim/src/query/factories.ts, only worldQueryForServiceRole() may
# read this. See DESIGN.md and the "Service-role key boundary" note in the
# first-feature design spec.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------
# Site URL — used to build magic-link auth callback URLs
# ---------------------------------------------------------------
# Dev:  http://localhost:3000
# Prod: https://your-prod-domain (set via `vercel env add ... production`)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
