{
  "name": "mauro",
  "version": "0.0.0",
  "private": true,
  "description": "Worldbuilding workspace for TTRPG GMs and worldbuilding novelists.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\""
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "prettier": "3.3.3",
    "turbo": "2.1.3",
    "typescript": "5.6.2"
  }
}
